---
import Icon from '../Icon.astro';

interface Props {
  listEndpoint: string;
  metaEndpoint: string;
}

const { listEndpoint, metaEndpoint } = Astro.props;
---

<dialog
  class="admin-media-picker"
  data-admin-media-picker
  data-list-endpoint={listEndpoint}
  data-meta-endpoint={metaEndpoint}
  aria-labelledby="admin-media-picker-title"
>
  <div class="admin-media-picker__surface">
    <div class="admin-media-picker__header">
      <div class="admin-media-picker__copy">
        <h2 id="admin-media-picker-title" class="admin-media-picker__title" data-admin-media-picker-title>
          选择本地图片
        </h2>
        <p
          id="admin-media-picker-description"
          class="admin-media-picker__description"
          data-admin-media-picker-description
          hidden
        ></p>
      </div>
      <button
        class="admin-media-picker__icon-btn"
        type="button"
        data-admin-media-picker-close
        aria-label="关闭"
        title="关闭"
      >
        <Icon name="x-mark" size={18} />
      </button>
    </div>

    <div class="admin-media-picker__toolbar">
      <div class="admin-media-picker__controls">
        <div class="admin-media-picker__search-row">
          <label class="admin-field admin-media-picker__search">
            <span class="admin-sr-only">搜索路径或文件名</span>
            <input
              type="search"
              inputmode="search"
              autocomplete="off"
              placeholder="搜索路径或文件名，例如 hero / avatar / bits-demo"
              data-admin-media-picker-query
            />
          </label>
          <p class="admin-media-picker__status" data-admin-media-picker-status aria-live="polite">等待加载</p>
        </div>

        <div class="admin-media-picker__filters" data-admin-media-picker-filters hidden>
          <div class="admin-media-picker__filter-tabs" data-admin-media-picker-filter-tabs></div>
        </div>
      </div>

      <div class="admin-media-picker__tool-actions">
        <button
          class="admin-media-picker__tool-btn"
          type="button"
          data-admin-media-picker-view="list"
          aria-label="列表视图"
          title="列表视图"
        >
          <Icon name="list" size={18} />
        </button>
        <button
          class="admin-media-picker__tool-btn"
          type="button"
          data-admin-media-picker-view="grid"
          aria-label="网格平铺视图"
          title="网格平铺视图"
        >
          <Icon name="grid-tiles" size={18} />
        </button>
        <button
          class="admin-media-picker__filter-toggle"
          type="button"
          data-admin-media-picker-filter-toggle
          aria-expanded="false"
          hidden
        >
          <Icon name="funnel" size={16} />
          <span>筛选</span>
        </button>
      </div>
    </div>

    <ul class="admin-media-picker__results" data-admin-media-picker-results data-view="list"></ul>

    <div class="admin-media-picker__footer">
      <div class="admin-media-picker__footer-side admin-media-picker__footer-side--start">
        <button class="admin-btn admin-btn--ghost" type="button" data-admin-media-picker-reset hidden>恢复默认</button>
      </div>
      <div class="admin-media-picker__pager" role="group" aria-label="媒体列表分页">
        <button
          class="admin-btn admin-btn--ghost admin-media-picker__pager-btn"
          type="button"
          data-admin-media-picker-prev
          aria-label="上一页"
          title="上一页"
        >
          <Icon
            name="chevron-down"
            size={22}
            class="admin-media-picker__pager-icon admin-media-picker__pager-icon--prev"
          />
        </button>
        <span class="admin-media-picker__page" data-admin-media-picker-page aria-live="polite">1 / 1</span>
        <button
          class="admin-btn admin-btn--ghost admin-media-picker__pager-btn"
          type="button"
          data-admin-media-picker-next
          aria-label="下一页"
          title="下一页"
        >
          <Icon
            name="chevron-down"
            size={22}
            class="admin-media-picker__pager-icon admin-media-picker__pager-icon--next"
          />
        </button>
      </div>
      <div class="admin-media-picker__footer-side admin-media-picker__footer-side--end">
        <div class="admin-media-picker__actions">
          <button class="admin-btn" type="button" data-admin-media-picker-confirm disabled>使用所选图片</button>
        </div>
      </div>
    </div>
  </div>
</dialog>
