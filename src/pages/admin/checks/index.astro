---
import Icon from '../../../components/Icon.astro';
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import {
  getAdminChecksData,
  isAdminChecksCategoryId,
  type AdminChecksCategoryId,
  type AdminChecksFilterValue
} from '../../../lib/admin-console/checks';
import { createWithBase } from '../../../utils/format';

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { default: adminShellStylesHref } = await import('../../../styles/components/admin-shell.css?url');

const selectedCategoryParam = Astro.url.searchParams.get('category')?.trim() ?? '';
const selectedCategory: AdminChecksFilterValue = isAdminChecksCategoryId(selectedCategoryParam)
  ? selectedCategoryParam
  : 'all';

const loadChecksDevState = async () => {
  const [{ default: adminChecksScriptHref }, { default: adminChecksStylesHref }] = await Promise.all([
    import('../../../scripts/admin-checks/index.ts?url'),
    import('../../../styles/components/admin-checks.css?url')
  ]);

  return {
    adminChecksScriptHref,
    stylesHref: [adminShellStylesHref, adminChecksStylesHref],
    checks: await getAdminChecksData()
  };
};

const checksDevState = isDev ? await loadChecksDevState() : null;
const adminStylesHref = checksDevState?.stylesHref ?? adminShellStylesHref;
const visibleCategories = checksDevState
  ? (
      selectedCategory === 'all'
        ? checksDevState.checks.categories
        : checksDevState.checks.categories.filter((category) => category.id === selectedCategory)
    )
  : [];

const buildChecksHref = (category: AdminChecksFilterValue): string => {
  const params = new URLSearchParams();
  if (category !== 'all') params.set('category', category);
  const query = params.toString();
  return withBase(`/admin/checks/${query ? `?${query}` : ''}`);
};
---

<AdminLayout title="Checks Console" stylesHref={adminStylesHref}>
  <AdminShell
    currentRoute="checks"
    title="Checks Console"
    subtitle="后台诊断"
    modeLabel={isDev ? 'DEV 快速扫描' : '只读模式'}
  >
    {isDev ? (
      <p
        slot="status"
        class="admin-sr-only"
        data-admin-checks-status-live
        role="status"
        aria-live="polite"
        aria-atomic="true"
      ></p>
    ) : null}
    {
      isDev && checksDevState ? (
        <section class="admin-overview admin-checks-console">
          <header class="admin-overview-card admin-checks-toolbar" aria-labelledby="admin-checks-title">
            <div class="admin-checks-toolbar__summary">
              <div class="admin-checks-toolbar__copy">
                <h2 id="admin-checks-title" class="admin-overview-card__title admin-checks-toolbar__title">诊断概览</h2>
                <p class="admin-checks-toolbar__body">
                  {
                    checksDevState.checks.totalIssueCount > 0
                      ? `当前共发现 ${checksDevState.checks.totalIssueCount} 个问题，分布在 ${checksDevState.checks.blockedCategoryCount} 个分类，涉及 ${checksDevState.checks.affectedPathCount} 个文件。`
                      : '当前检查范围内未发现问题'
                  }
                </p>
              </div>

              <form
                class="admin-checks-toolbar__action"
                method="get"
                action={withBase('/admin/checks/')}
                data-admin-checks-refresh-form
              >
                {selectedCategory !== 'all' ? <input type="hidden" name="category" value={selectedCategory} /> : null}
                <button class="admin-checks-toolbar__refresh-link" type="submit" data-admin-checks-refresh-button>
                  重新检测
                </button>
              </form>
            </div>

            <p class="admin-checks-toolbar__hint">
              注：提交前仍建议执行 <code>npm run check</code>、<code>npm test</code>、<code>npm run build</code>。
            </p>
          </header>

          <nav class="admin-checks-toolbar__filters" aria-label="检查分类筛选">
            <a
              href={buildChecksHref('all')}
              class:list={['admin-checks-filter', selectedCategory === 'all' && 'is-active']}
              aria-current={selectedCategory === 'all' ? 'page' : undefined}
            >
              <span class="admin-checks-filter__label">全部</span>
              <span class="admin-checks-filter__count">{checksDevState.checks.totalIssueCount}</span>
            </a>
            {
              checksDevState.checks.categories.map((category) => (
                <a
                  href={buildChecksHref(category.id as AdminChecksCategoryId)}
                  class:list={['admin-checks-filter', selectedCategory === category.id && 'is-active']}
                  aria-current={selectedCategory === category.id ? 'page' : undefined}
                >
                  <span class="admin-checks-filter__label">{category.label}</span>
                  <span class="admin-checks-filter__count">{category.issueCount}</span>
                </a>
              ))
            }
          </nav>

          {
            visibleCategories.map((category) => (
              <article class="admin-checks-category" data-status={category.status}>
                <div class="admin-checks-category__head">
                  <div class="admin-checks-category__copy">
                    {
                      selectedCategory !== 'all' ? (
                        <div class="admin-checks-category__title-row">
                          <h2 class="admin-checks-category__title">{category.label}</h2>
                          <span class="admin-checks-category__description">{category.description}</span>
                        </div>
                      ) : (
                        <h2 class="admin-checks-category__title">{category.label}</h2>
                      )
                    }
                  </div>
                  <span
                    class:list={[
                      'admin-checks-status',
                      category.issueCount > 0 ? 'admin-checks-status--error' : 'admin-checks-status--ok'
                    ]}
                  >
                    {category.issueCount > 0 ? `${category.issueCount} 个问题` : '正常'}
                  </span>
                </div>

                {
                  category.issueCount > 0 ? (
                    <ol class="admin-checks-issue-list">
                      {
                        category.issues.map((issue) => (
                          <li class="admin-checks-issue">
                            <span class="admin-checks-issue__icon" aria-hidden="true">
                              <Icon name="x-mark" class="admin-checks-issue__icon-mark" size={10} />
                            </span>
                            <div class="admin-checks-issue__body">
                              <div class="admin-checks-issue__head">
                                <div class="admin-checks-issue__copy">
                                  <h3 class="admin-checks-issue__title">{issue.title}</h3>
                                  <p class="admin-checks-issue__message">{issue.message}</p>
                                  {issue.detail ? <p class="admin-checks-issue__detail">{issue.detail}</p> : null}
                                </div>
                                {
                                  issue.href ? (
                                    <a class="admin-checks-issue__link" href={withBase(issue.href)}>查看详情</a>
                                  ) : null
                                }
                              </div>

                              <p class="admin-checks-issue__meta">
                                {
                                  issue.collection ? (
                                    <span class="admin-checks-meta-item">
                                      <span class="admin-checks-meta-item__label">collection:</span>
                                      <span class="admin-checks-meta-item__value">{issue.collection}</span>
                                    </span>
                                  ) : null
                                }
                                {
                                  issue.entryId ? (
                                    <span class="admin-checks-meta-item">
                                      <span class="admin-checks-meta-item__label">entry.id:</span>
                                      <code class="admin-checks-meta-item__value">{issue.entryId}</code>
                                    </span>
                                  ) : null
                                }
                                {
                                  issue.fieldPath ? (
                                    <span class="admin-checks-meta-item">
                                      <span class="admin-checks-meta-item__label">field:</span>
                                      <code class="admin-checks-meta-item__value">{issue.fieldPath}</code>
                                    </span>
                                  ) : null
                                }
                                {
                                  issue.relativePath ? (
                                    <span class="admin-checks-meta-item">
                                      <span class="admin-checks-meta-item__label">path:</span>
                                      <code class="admin-checks-meta-item__value">{issue.relativePath}</code>
                                    </span>
                                  ) : null
                                }
                              </p>
                            </div>
                          </li>
                        ))
                      }
                    </ol>
                  ) : (
                    <p class="admin-checks-empty">
                      <span class="admin-checks-empty__icon" aria-hidden="true">✓</span>
                      <span>当前分类未发现问题</span>
                    </p>
                  )
                }
              </article>
            ))
          }
        </section>
      ) : (
        <section class="admin-overview">
          <div class="admin-overview__grid">
            <article class="admin-overview-card">
              <p class="admin-overview-card__eyebrow">Readonly Boundary</p>
              <h2 class="admin-overview-card__title">Checks Console 仅在本地开发环境可用</h2>
              <p class="admin-overview-card__body">
                当前环境继续保留 `/admin/checks/` 稳定子入口，但不输出结构化诊断结果，也不代替发布前 CLI 校验。
              </p>
              <div class="admin-overview-card__actions">
                <a class="admin-btn admin-btn--ghost" href={withBase('/admin/')}>返回 Admin 首页</a>
                <a class="admin-btn admin-btn--ghost" href={withBase('/admin/theme/')}>查看 Theme 子入口</a>
              </div>
            </article>

            <article class="admin-overview-card">
              <p class="admin-overview-card__eyebrow">CLI Baseline</p>
              <h2 class="admin-overview-card__title">结构化摘要不替代终端检查</h2>
              <p class="admin-overview-card__body">
                当前页面只展示源文件层高价值问题；`check:preview-admin`、构建产物断言与完整 build smoke check 仍在终端执行。
              </p>
            </article>
          </div>
        </section>
      )
    }
  </AdminShell>

  {
    isDev && checksDevState?.adminChecksScriptHref ? (
      <script is:inline type="module" src={checksDevState.adminChecksScriptHref}></script>
    ) : null
  }
</AdminLayout>
