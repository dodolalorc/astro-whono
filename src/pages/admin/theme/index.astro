---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminMediaPicker from '../../../components/admin/AdminMediaPicker.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import { createWithBase } from '../../../utils/format';

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const adminMediaListEndpoint = withBase('/api/admin/media/list');
const adminMediaMetaEndpoint = withBase('/api/admin/media/meta');

const loadThemeDevState = async () => {
  const [
    { getEntry },
    { getEditableThemeSettingsState },
    {
      ADMIN_FOOTER_START_YEAR_MIN,
      ADMIN_HOME_INTRO_MAX_LENGTH,
      ADMIN_NAV_IDS,
      ADMIN_NAV_ORNAMENT_DEFAULT,
      ADMIN_PAGE_SUBTITLE_MAX_LENGTH,
      ADMIN_PAGE_TITLE_MAX_LENGTH,
      ADMIN_SOCIAL_CUSTOM_LIMIT,
      getAdminFooterStartYearMax
    },
    { default: AdminHomeSection },
    { default: AdminPageSection },
    { default: AdminSidebarSection },
    { default: AdminSiteSection },
    { default: AdminUiSection },
    { default: adminConsoleScriptHref },
    { default: adminStylesHref }
  ] = await Promise.all([
    import('astro:content'),
    import('../../../lib/theme-settings'),
    import('../../../lib/admin-console/theme-shared'),
    import('../../../components/admin/AdminHomeSection.astro'),
    import('../../../components/admin/AdminPageSection.astro'),
    import('../../../components/admin/AdminSidebarSection.astro'),
    import('../../../components/admin/AdminSiteSection.astro'),
    import('../../../components/admin/AdminUiSection.astro'),
    import('../../../scripts/admin-console/index.ts?url'),
    import('../../../styles/components/admin.css?url')
  ]);

  const settingsEndpoint = withBase('/api/admin/settings/');
  const navIdOrder = ADMIN_NAV_IDS;
  const navLabelFallback = {
    essay: '随笔',
    bits: '絮语',
    memo: '小记',
    archive: '归档',
    about: '关于'
  } as const;
  const footerStartYearMin = ADMIN_FOOTER_START_YEAR_MIN;
  const footerStartYearMax = getAdminFooterStartYearMax();
  const homeIntroMaxLength = ADMIN_HOME_INTRO_MAX_LENGTH;
  const pageTitleMaxLength = ADMIN_PAGE_TITLE_MAX_LENGTH;
  const pageSubtitleMaxLength = ADMIN_PAGE_SUBTITLE_MAX_LENGTH;
  const socialCustomLimit = ADMIN_SOCIAL_CUSTOM_LIMIT;
  const memoEntry = await getEntry('memo', 'index');
  const memoTitlePlaceholder = typeof memoEntry?.data.title === 'string' ? memoEntry.data.title.trim() : '';
  const memoSubtitlePlaceholder =
    typeof memoEntry?.data.subtitle === 'string' ? memoEntry.data.subtitle.trim() : '';

  const initialState = getEditableThemeSettingsState();
  const bootstrapState = initialState.ok
    ? (() => {
        const initialNavMap = new Map(
          initialState.payload.settings.shell.nav.map((item) => [item.id, item])
        );

        return {
          ok: true as const,
          payload: {
            revision: initialState.payload.revision,
            settings: {
              ...initialState.payload.settings,
              shell: {
                ...initialState.payload.settings.shell,
                nav: navIdOrder.map((id, index) => {
                  const current = initialNavMap.get(id);
                  if (current) return current;
                  return {
                    id,
                    label: navLabelFallback[id],
                    ornament: ADMIN_NAV_ORNAMENT_DEFAULT,
                    visible: true,
                    order: index + 1
                  };
                })
              }
            },
            sources: initialState.payload.sources
          }
        };
      })()
    : initialState;

  return {
    AdminHomeSection,
    AdminPageSection,
    AdminSidebarSection,
    AdminSiteSection,
    AdminUiSection,
    adminConsoleScriptHref,
    adminStylesHref,
    bootstrapText: JSON.stringify(bootstrapState),
    footerStartYearMin,
    footerStartYearMax,
    homeIntroMaxLength,
    memoSubtitlePlaceholder,
    memoTitlePlaceholder,
    navIdOrder,
    pageSubtitleMaxLength,
    pageTitleMaxLength,
    settingsEndpoint,
    socialCustomLimit
  };
};

const adminDevState = isDev ? await loadThemeDevState() : null;
const AdminHomeSection = adminDevState?.AdminHomeSection;
const AdminPageSection = adminDevState?.AdminPageSection;
const AdminSidebarSection = adminDevState?.AdminSidebarSection;
const AdminSiteSection = adminDevState?.AdminSiteSection;
const AdminUiSection = adminDevState?.AdminUiSection;
---

<AdminLayout title="Theme Console" stylesHref={adminDevState?.adminStylesHref ?? null}>
  <AdminShell
    currentRoute="theme"
    title="Theme Console"
    subtitle="主题设置"
    description="沿用现有 settings bootstrap、校验、dry-run、revision 冲突保护与事务写盘链路；Phase 0 只迁移路由壳层，不改保存契约。"
    modeLabel={isDev ? 'DEV 可写' : '只读模式'}
    modeHint={isDev ? '当前页面可直接编辑 src/data/settings/*.json 对应配置。' : 'Theme Console 仅在本地开发环境可写；生产与 preview 仅保留只读边界。'}
  >
    {isDev ? (
      <div slot="status" class="admin-status-slot">
        <p id="admin-status-live" class="admin-sr-only" role="status" aria-live="polite" aria-atomic="true"></p>
        <p id="admin-status" class="admin-status" data-state="idle">等待加载</p>
      </div>
    ) : null}
    {
      isDev && adminDevState && AdminHomeSection && AdminPageSection && AdminSidebarSection && AdminSiteSection && AdminUiSection ? (
        <>
          <section class="admin-theme-console" data-admin-root data-settings-endpoint={adminDevState.settingsEndpoint}>
            <section
              id="admin-error-banner"
              class="admin-banner admin-banner--error"
              hidden
              role="alert"
              aria-atomic="true"
              tabindex="-1"
            >
              <div class="admin-banner__header">
                <div class="admin-banner__lead">
                  <span class="admin-banner__icon" aria-hidden="true">×</span>
                  <div class="admin-banner__copy">
                    <p id="admin-error-title" class="admin-banner__title">操作未完成</p>
                    <p id="admin-error-message" class="admin-banner__message" hidden></p>
                  </div>
                </div>
                <button
                  id="admin-error-retry"
                  class="admin-btn admin-btn--ghost admin-btn--danger admin-banner__retry"
                  type="button"
                  hidden
                >
                  重新检查
                </button>
              </div>
              <ul id="admin-error-list" class="admin-banner__list" hidden></ul>
            </section>

            <form id="admin-form" class="admin-form" novalidate>
              <AdminSiteSection
                footerStartYearMin={adminDevState.footerStartYearMin}
                footerStartYearMax={adminDevState.footerStartYearMax}
                socialCustomLimit={adminDevState.socialCustomLimit}
              />

              <AdminSidebarSection navIdOrder={adminDevState.navIdOrder} />

              <AdminHomeSection homeIntroMaxLength={adminDevState.homeIntroMaxLength} />

              <AdminPageSection
                pageTitleMaxLength={adminDevState.pageTitleMaxLength}
                pageSubtitleMaxLength={adminDevState.pageSubtitleMaxLength}
                memoTitlePlaceholder={adminDevState.memoTitlePlaceholder}
                memoSubtitlePlaceholder={adminDevState.memoSubtitlePlaceholder}
              />

              <AdminUiSection />
            </form>

            <div id="admin-actions-sentinel" class="admin-actions__sentinel" aria-hidden="true"></div>
            <div id="admin-actions" class="admin-actions" data-dirty="false" data-sticky="false">
              <div class="admin-actions__meta">
                <p id="admin-dirty-banner" class="admin-banner admin-banner--dirty" hidden>
                  * 你有未保存更改，离开页面会触发提醒。
                </p>
                <p id="admin-status-inline" class="admin-status admin-status--inline" data-state="idle" aria-hidden="true">
                  等待加载
                </p>
              </div>
              <div class="admin-actions__buttons">
                <button id="admin-validate" class="admin-btn" type="button">检查配置</button>
                <button id="admin-reset" class="admin-btn admin-btn--ghost" type="button">重置更改</button>
                <button id="admin-save" class="admin-btn admin-btn--muted" type="button">保存</button>
              </div>
            </div>

            <div id="admin-bootstrap" hidden>{adminDevState.bootstrapText}</div>
          </section>
        </>
      ) : (
        <section class="admin-overview-card">
          <p class="admin-overview-card__eyebrow">Readonly Boundary</p>
          <h2 class="admin-overview-card__title">Theme Console 仅在本地开发环境可写</h2>
          <p class="admin-overview-card__body">
            当前路由继续保留为稳定子入口，用于验证 `/admin/theme/` 在 preview / production 下的只读边界。
          </p>
          <p class="admin-overview-card__meta">若需修改配置，请在本地运行 `npm run dev` 后从此入口进入。</p>
        </section>
      )
    }
  </AdminShell>
  {isDev ? <AdminMediaPicker listEndpoint={adminMediaListEndpoint} metaEndpoint={adminMediaMetaEndpoint} /> : null}

  {
    isDev && adminDevState?.adminConsoleScriptHref ? (
      <script is:inline type="module" src={adminDevState.adminConsoleScriptHref}></script>
    ) : null
  }
</AdminLayout>
