---
import Icon from '../../../components/Icon.astro';
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminReadonlyNotice from '../../../components/admin/AdminReadonlyNotice.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import {
  ADMIN_MEDIA_LIST_API_PATH,
  ADMIN_MEDIA_META_API_PATH,
  invalidateAdminMediaCaches,
  listAdminMediaBrowseIndex,
  listAdminMediaScopeIndex,
  type AdminMediaBrowseIndexItem,
  type AdminMediaScopeIndex
} from '../../../lib/admin-console/media-shared';
import { createWithBase } from '../../../utils/format';

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { default: adminShellStylesHref } = await import('../../../styles/components/admin-shell.css?url');
const DEFAULT_MEDIA_GROUP = 'all' as const;
const DEFAULT_MEDIA_SCOPE = '' as const;

const rawGroup = Astro.url.searchParams.get('group')?.trim().toLowerCase() ?? DEFAULT_MEDIA_GROUP;
const rawScope = Astro.url.searchParams.get('scope')?.trim().toLowerCase() ?? DEFAULT_MEDIA_SCOPE;
const rawSubgroup = Astro.url.searchParams.get('sub')?.trim() ?? '';
const rawQuery = Astro.url.searchParams.get('q')?.trim() ?? '';
const hasInitialQuery = rawQuery.length > 0;
const rawPage = Number.parseInt(Astro.url.searchParams.get('page')?.trim() ?? '1', 10);
const shouldRefresh = Astro.url.searchParams.get('refresh')?.trim() === '1';
const selectedGroup = rawGroup || DEFAULT_MEDIA_GROUP;
const selectedScope = rawScope === 'recent' ? 'recent' : DEFAULT_MEDIA_SCOPE;
const selectedSubgroup = selectedGroup === DEFAULT_MEDIA_GROUP ? '' : rawSubgroup;
const selectedPage = Number.isInteger(rawPage) && rawPage > 0 ? rawPage : 1;

const loadMediaDevState = async (): Promise<{
  adminMediaScriptHref: string;
  stylesHref: readonly string[];
  browseIndex: AdminMediaBrowseIndexItem[] | null;
  scopeIndex: AdminMediaScopeIndex;
  didRefresh: boolean;
}> => {
  if (shouldRefresh) {
    invalidateAdminMediaCaches();
  }

  const [{ default: adminMediaScriptHref }, { default: adminMediaStylesHref }] = await Promise.all([
    import('../../../scripts/admin-media/index.ts?url'),
    import('../../../styles/components/admin-media.css?url')
  ]);
  const [browseIndex, scopeIndex] = await Promise.all([
    listAdminMediaBrowseIndex().catch(() => null),
    listAdminMediaScopeIndex().catch(() => ({ recent: [] }))
  ]);

  return {
    adminMediaScriptHref,
    stylesHref: [adminShellStylesHref, adminMediaStylesHref],
    browseIndex,
    scopeIndex,
    didRefresh: shouldRefresh
  };
};

const mediaDevState = isDev ? await loadMediaDevState() : null;
const bootstrapText = mediaDevState
  ? JSON.stringify({
      listEndpoint: withBase(ADMIN_MEDIA_LIST_API_PATH),
      metaEndpoint: withBase(ADMIN_MEDIA_META_API_PATH),
      initialState: {
        scope: selectedScope,
        group: selectedGroup,
        subgroup: selectedSubgroup,
        query: rawQuery,
        page: selectedPage
      },
      browseIndex: mediaDevState.browseIndex,
      scopeIndex: mediaDevState.scopeIndex,
      didRefresh: mediaDevState.didRefresh
    })
  : null;
---

<AdminLayout title="Media Console" stylesHref={mediaDevState?.stylesHref ?? adminShellStylesHref}>
  <AdminShell
    currentRoute="media"
    title="Media Console"
    subtitle="图库"
    showNav={isDev}
  >
    {isDev ? (
      <div slot="status" class="admin-status-slot">
        <p id="admin-media-status-live" class="admin-sr-only" role="status" aria-live="polite" aria-atomic="true"></p>
        <p id="admin-media-status" class="admin-status" data-state="idle">准备中</p>
      </div>
    ) : null}

    {
      isDev && bootstrapText ? (
        <section class="admin-overview admin-media-console" data-admin-media-root>
          <form id="admin-media-form" class="admin-overview-card admin-media-browser__controls">
            <div class="admin-media-browser__head">
              <div class="admin-media-browser__copy">
                <h2 class="admin-overview-card__title">图片管理</h2>
              </div>

              <div class="admin-media-browser__search-row">
                <div
                  id="admin-media-search-panel"
                  class="admin-media-browser__search-panel"
                  data-open={hasInitialQuery ? 'true' : 'false'}
                  aria-hidden={hasInitialQuery ? 'false' : 'true'}
                >
                  <label class="admin-media-browser__search-shell" for="admin-media-query">
                    <span class="admin-sr-only">搜索图片</span>
                    <input
                      id="admin-media-query"
                      name="q"
                      type="search"
                      inputmode="search"
                      tabindex={hasInitialQuery ? undefined : '-1'}
                      value={rawQuery}
                      placeholder="搜索图片"
                      autocomplete="off"
                    />
                  </label>
                </div>

                <div class="admin-media-browser__tool-actions">
                  <button
                    id="admin-media-search-toggle"
                    class="admin-media-browser__tool-btn"
                    type="button"
                    aria-label="搜索图片"
                    aria-controls="admin-media-search-panel"
                    aria-expanded={hasInitialQuery ? 'true' : 'false'}
                    data-active={hasInitialQuery ? 'true' : 'false'}
                    title="搜索图片"
                  >
                    <Icon name="search" />
                  </button>

                  <button
                    id="admin-media-refresh"
                    class="admin-media-browser__tool-btn"
                    type="button"
                    aria-label="刷新媒体库并重置筛选"
                    title="刷新媒体库并重置筛选"
                  >
                    <Icon name="refresh" />
                  </button>
                </div>

                <button id="admin-media-recent" class="admin-media-browser__recent-link" type="button">最近修改</button>
              </div>
            </div>

            <div class="admin-media-browser__filters">
              <div id="admin-media-groups-wrap" class="admin-media-browser__filter-group">
                <div class="admin-media-browser__filter-head">
                  <p class="admin-media-browser__filter-label">
                    <Icon name="grid-tiles" class="admin-media-browser__filter-label-icon" size={13} />
                    <span>使用场景</span>
                  </p>
                  <button id="admin-media-show-uncategorized" class="admin-btn admin-btn--ghost" type="button" hidden>
                    显示未归类
                  </button>
                </div>
                <div id="admin-media-groups" class="admin-media-browser__chips"></div>
              </div>

              <div id="admin-media-subgroups-wrap" class="admin-media-browser__filter-group" hidden>
                <p class="admin-media-browser__filter-label">
                  <Icon name="branch-nodes" class="admin-media-browser__filter-label-icon" size={13} />
                  <span>应用位置</span>
                </p>
                <div id="admin-media-subgroups" class="admin-media-browser__chips"></div>
              </div>
            </div>
          </form>

          <article class="admin-overview-card admin-media-browser__results">
            <ul id="admin-media-result-list" class="admin-media-browser__grid"></ul>
            <p id="admin-media-empty" class="admin-content-empty" hidden>没有找到符合条件的图片。</p>

            <div class="admin-media-browser__pager">
              <p id="admin-media-page-meta" class="admin-overview-card__meta">第 1 / 1 页</p>
              <div class="admin-overview-card__actions">
                <button id="admin-media-prev" class="admin-btn admin-btn--ghost" type="button" disabled>上一页</button>
                <button id="admin-media-next" class="admin-btn admin-btn--ghost" type="button" disabled>下一页</button>
              </div>
            </div>
          </article>

          <article id="admin-media-detail" class="admin-overview-card admin-media-browser__detail" hidden></article>

          <div id="admin-media-icon-library" hidden aria-hidden="true">
            <span data-icon="copy"><Icon name="copy" size={15} /></span>
            <span data-icon="link"><Icon name="link" size={15} /></span>
            <span data-icon="eye"><Icon name="eye" size={15} /></span>
          </div>

          <div id="admin-media-bootstrap" hidden>{bootstrapText}</div>
        </section>
      ) : (
        <AdminReadonlyNotice>
          若需浏览媒体库或复制资源路径，请在本地运行 <code translate="no">npm run dev</code> 后从此入口进入。
        </AdminReadonlyNotice>
      )
    }
  </AdminShell>

  {
    isDev && mediaDevState?.adminMediaScriptHref ? (
      <script is:inline type="module" src={mediaDevState.adminMediaScriptHref}></script>
    ) : null
  }
</AdminLayout>
